{
  "name": "incident-report-management",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npm install --include=dev && npx vite build",
    "build:server": "cd server && npm install",
    "build:all": "npm run build && npm run build:server && npm run seed",
    "start": "cd server && NODE_ENV=production node index.js",
    "seed": "cd server && node db/seed.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "puppeteer": "^24.43.0"
  }
}
